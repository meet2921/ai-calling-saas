# Security
SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=300
REFRESH_TOKEN_EXPIRE_DAYS=7
DEBUG=False

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/saas_db
SYNC_DATABASE_URL=postgresql://user:password@localhost:5432/saas_db

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CAMPAIGN_BROKER_URL=redis://localhost:6379/0
CAMPAIGN_RESULT_BACKEND=redis://localhost:6379/0

# Bolna AI
BOLNA_API_KEY=your-bolna-api-key
BOLNA_API_URL=https://api.bolna.ai/v2
BOLNAMAKE_CALL_URL=https://api.bolna.ai
WEBHOOK_BASE_URL=https://your-ngrok-or-domain.com
BOLNA_WEBHOOK_SECRET=your-bolna-webhook-secret

# Frontend
APP_NAME=MyApp
FRONTEND_URL=https://app.myapp.com
PASSWORD_RESET_EXPIRE_HOURS=24

# SMTP / Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-app-password
SMTP_STARTTLS=true
SMTP_TLS=false
SMTP_FROM_NAME=Your App Name
SMTP_FROM_EMAIL=your-email@example.com
